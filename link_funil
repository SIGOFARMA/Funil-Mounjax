<title>Mídias do Funil - Mounjax</title>
<style>
    /* Estilos Gerais */
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #0f0f12;
        color: #eee;
        padding: 40px 20px;
        margin: 0;
    }

    .container {
        max-width: 800px;
        margin: 0 auto;
    }

    h1 {
        color: #b388ff;
        text-align: center;
        margin-bottom: 40px;
        font-weight: 300;
        letter-spacing: 1px;
    }

    h2 {
        color: #d1b3ff;
        border-bottom: 1px solid #333;
        padding-bottom: 10px;
        margin-top: 40px;
        font-weight: 400;
    }

    /* Estilos da Lista e Links */
    ul {
        list-style-type: none;
        padding: 0;
    }

    li {
        background: #1c1c22;
        margin-bottom: 12px;
        border-radius: 8px;
        border: 1px solid #2a2a35;
        /* Preparação para a animação de hover */
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
        /* Aplicação da animação de entrada */
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    /* Efeito ao passar o mouse (Hover) */
    li:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 15px rgba(179, 136, 255, 0.15);
        background: #23232a;
    }

    a {
        color: #8ecaff;
        text-decoration: none;
        display: block; /* Faz o link ocupar toda a área do item */
        padding: 16px 20px;
        font-weight: 500;
    }

    /* Estilo para a caixa de instruções */
    .instructions {
        background: #251d35;
        border-left: 4px solid #b388ff;
        padding: 20px;
        border-radius: 4px;
        margin-top: 40px;
        line-height: 1.6;
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
    }

    .instructions-title {
        color: #b388ff;
        font-weight: bold;
        margin-bottom: 10px;
    }

    /* Animação Keyframes (Surge de baixo para cima) */
    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Atraso sequencial para criar um efeito de cascata nas listas */
    li:nth-child(1) { animation-delay: 0.1s; }
    li:nth-child(2) { animation-delay: 0.15s; }
    li:nth-child(3) { animation-delay: 0.2s; }
    li:nth-child(4) { animation-delay: 0.25s; }
    li:nth-child(5) { animation-delay: 0.3s; }
    li:nth-child(6) { animation-delay: 0.35s; }
    li:nth-child(n+7) { animation-delay: 0.4s; }
</style>
</head>

